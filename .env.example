DB_HOST=mysql
DB_PORT=3307
# Keep DB_NAME aligned with mysql/CloudStoreDB.sql unless you update the SQL dump too.
DB_NAME=cloudstore_db
DB_USER=user
DB_PASSWORD=pwd
DB_SSL_MODE=PREFERRED
DB_SERVER_TIMEZONE=UTC
DB_ALLOW_PUBLIC_KEY_RETRIEVAL=true

SERVER_BIND_ADDRESS=0.0.0.0
SERVER_PORT=9999

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS_ENABLED=false

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=cloudstore
RABBITMQ_PASSWORD=change-me
RABBITMQ_VHOST=/
RABBITMQ_TLS_ENABLED=false

BACKEND_SCHEME=http

# --- SECURITY (JWT) ---
# [CRITICAL] Must be a Base64-encoded string.
# After decoding, it MUST result in at least 32 bytes (256 bits) for HS256.
# Generate via: openssl rand -base64 32
# The application will not start while this value is empty.
JWT_SECRET= 

# [REQUIRED] Validity in milliseconds. Recommended: 3600000 (1h)
JWT_EXPIRATION_MS=3600000

# [REQUIRED] String identifier for the token issuer (e.g., "cloudstore-auth")
JWT_ISSUER=cloudstore-auth

# [REQUIRED] String identifier for the intended audience
JWT_AUDIENCE=cloudstore-client
